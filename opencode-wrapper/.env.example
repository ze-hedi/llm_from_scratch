# API Keys for OpenClaw/OpenCode
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to version control!

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenClaw API Key (if applicable)
OPENCLAW_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Note: In CI/CD, these are stored as GitHub Secrets
# Go to: Repository Settings → Secrets and variables → Actions → New repository secret
